{
  "name": "wasona",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "cap:sync": "node scripts/fetch-kalama.mjs && PUBLIC_KALAMA_BASE=/kalama astro build && cap sync android",
    "cap:open": "cap open android",
    "cap:run": "npm run cap:sync && cap run android",
    "cap:assets": "capacitor-assets generate --android --iconBackgroundColor '#d46000' --iconBackgroundColorDark '#d46000' --splashBackgroundColor '#ffffff' --splashBackgroundColorDark '#3c200a'",
    "cap:apk": "npm run cap:sync && android/gradlew -p android assembleDebug",
    "cap:install": "npm run cap:sync && android/gradlew -p android installDebug",
    "cap:launch": "adb shell am start -n com.wasona.app/.MainActivity",
    "cap:deploy": "npm run cap:install && npm run cap:launch"
  },
  "dependencies": {
    "@astrojs/mdx": "^5.0.4",
    "@astrojs/rss": "^4.0.11",
    "@astrojs/sitemap": "^3.3.0",
    "@astrojs/svelte": "^8.0.5",
    "@capacitor/android": "^8.4.1",
    "@capacitor/app": "^8.1.0",
    "@capacitor/core": "^8.4.1",
    "astro": "^6.0.0",
    "selo-components": "github:AcipenserSturio/selo-components",
    "svelte": "^5.55.5"
  },
  "devDependencies": {
    "@capacitor/assets": "github:AcipenserSturio/capacitor-assets#chore/modernize-deps",
    "@capacitor/cli": "^8.4.1"
  },
  "allowScripts": {
    "sharp@0.32.6": true,
    "sharp@0.34.5": true
  }
}
