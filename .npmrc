# npm v12 blocks git-sourced dependencies by default (allow-git=none).
# This project deliberately uses two git deps that we own:
#   - selo-components               (github:AcipenserSturio/selo-components)
#   - @capacitor/assets (our fork)  (github:AcipenserSturio/capacitor-assets)
# `root` opts *this project only* into fetching git deps declared in our own
# package.json. It does NOT relax allow-remote (tarball URLs) or allowScripts
# (per-package install-script approval), which stay at their strict defaults.
allow-git=root
